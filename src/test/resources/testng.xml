<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-current.dtd">
<suite name="UI Automation Practice Suite" parallel="methods" thread-count="3">
    <test name="UI Automation Tests">
    <parameter name="browser" value="${browser}"/>
    <parameter name="isHeadless" value="${isHeadless}"/>
    <parameter name="isLambdaTest" value="${isLambdaTest}"/>
        <classes>
            <class name="com.ui.tests.LoginTest" />
            <class name="com.ui.tests.InvalidLoginTest" />
            <class name="com.ui.tests.PasswordResetTest" />
        </classes>
    </test>
</suite>
